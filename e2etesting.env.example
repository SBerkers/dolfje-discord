# e2etesting.env
# Environment variables for E2E testing the Discord bot

# The bot token for the Test Observer (a separate bot that verifies state in the server)
# Or the main bot token if you run the bot directly in the tests.
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# The Discord Server ID (Guild ID) where the E2E tests will run
DISCORD_GUILD_ID=your_discord_guild_id_here

# Test database credentials (these match the docker-compose setup)
DB_HOST=localhost
DB_PORT=5432
DB_USER=testuser
DB_PASS=testpass
DB_NAME=mnotww_test

# Admin password for destructive commands (like /stopgame or /archive)
MNOT_ADMIN_PASS=testadmin

# Application language
APPLANG=en
